{
  "private": true,
  "scripts": {
    "postinstall": "gem install bundler && bundle install",
    "start": "npm run build:watch & npm run start:jekyll",
    "start:jekyll": "bundle exec jekyll serve --baseurl= --livereload",
    "build": "npm run build:sass && npm run build:js",
    "build:js": "cp node_modules/anchor-js/anchor.min.js assets/js/app.js",
    "build:sass": "sass --load-path=node_modules src/sass:assets/css --no-source-map --style=compressed",
    "build:watch": "npm run build && sass --load-path=node_modules src/sass:assets/css --no-source-map --style=compressed --watch"
  },
  "author": "Ravindra Marella",
  "license": "MIT",
  "devDependencies": {
    "anchor-js": "^5.0.0",
    "bootstrap": "^5.3.8",
    "sass": "^1.99.0",
    "primer-base": "^2.0.0",
    "primer-layout": "^2.0.0",
    "primer-markdown": "^4.0.0",
    "primer-navigation": "^2.0.0",
    "primer-utilities": "^5.0.0"
  }
}
